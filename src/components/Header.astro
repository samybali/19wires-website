---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// 1. Logique d'ingénieur pour le sélecteur de langue (rester sur la même page)
const pathname = Astro.url.pathname;
// L'anglais est par défaut (à la racine)
const frPath = lang === 'fr' ? pathname : `/fr${pathname === '/' ? '' : pathname}`;
const enPath = lang === 'en' ? pathname : pathname.replace(/^\/fr/, '') || '/';

// 2. Préfixe automatique pour tous les liens du site
const basePath = lang === 'en' ? '/' : '/fr/';

// 3. On génère la navigation dynamiquement avec les traductions et le bon préfixe
const navLinks = [
  { label: lang === 'en' ? "Home" : "Accueil", href: basePath },
  { label: t('nav.services') || "Services", href: `${basePath}#services` },
  { label: t('nav.contact') || "Contact", href: `${basePath}contact` },
];
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-5">
      <a href={basePath} class="flex items-center transition-opacity hover:opacity-80">
        <span translate="no" class="notranslate font-sixtyfour text-xl tracking-tight text-white">
          <span class="text-[#003566]">19</span>WIRES
        </span>
      </a>

      <div class="w-px h-5 bg-zinc-800 hidden sm:block"></div>

      <div class="flex items-center p-0.5 rounded-full bg-zinc-900/50 border border-zinc-800 text-xs font-bold uppercase tracking-wide backdrop-blur-sm">
        <a
          href={enPath}
          class={`px-2.5 py-1 rounded-full transition-colors ${
            lang === 'en'
              ? 'bg-blue-500/20 text-blue-400 shadow-sm'
              : 'text-zinc-500 hover:text-zinc-200'
          }`}
        >
          EN
        </a>

        <a
          href={frPath}
          class={`px-2.5 py-1 rounded-full transition-colors ${
            lang === 'fr'
              ? 'bg-blue-500/20 text-blue-400 shadow-sm'
              : 'text-zinc-500 hover:text-zinc-200'
          }`}
        >
          FR
        </a>
      </div>
    </div>

    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-zinc-400 hover:text-white transition-colors duration-200 font-medium"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <a
      href={`${basePath}contact`}
      class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold transition-all duration-200 hover:shadow-lg hover:shadow-blue-500/25"
    >
      {t('nav.startProject')}
    </a>

    <button
      id="burger"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Menu"
    >
      <span class="w-6 h-0.5 bg-white transition-all duration-300" id="b1"></span>
      <span class="w-6 h-0.5 bg-white transition-all duration-300" id="b2"></span>
      <span class="w-6 h-0.5 bg-white transition-all duration-300" id="b3"></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden bg-zinc-900/95 backdrop-blur-md border-t border-zinc-800 px-6 py-4"
  >
    <nav class="flex flex-col gap-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-zinc-300 hover:text-white transition-colors font-medium py-1"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`${basePath}contact`}
        class="mt-2 inline-flex justify-center px-5 py-2.5 rounded-full bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold transition-colors"
      >
        {t('nav.startProject')}
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById("header");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header?.classList.add(
        "bg-zinc-950/80",
        "backdrop-blur-md",
        "border-b",
        "border-zinc-800/50"
      );
    } else {
      header?.classList.remove(
        "bg-zinc-950/80",
        "backdrop-blur-md",
        "border-b",
        "border-zinc-800/50"
      );
    }
  });

  const burger = document.getElementById("burger");
  const mobileMenu = document.getElementById("mobile-menu");
  const b1 = document.getElementById("b1");
  const b2 = document.getElementById("b2");
  const b3 = document.getElementById("b3");
  let isOpen = false;

  burger?.addEventListener("click", () => {
    isOpen = !isOpen;
    mobileMenu?.classList.toggle("hidden");
    if (isOpen) {
      b1?.classList.add("rotate-45", "translate-y-2");
      b2?.classList.add("opacity-0");
      b3?.classList.add("-rotate-45", "-translate-y-2");
    } else {
      b1?.classList.remove("rotate-45", "translate-y-2");
      b2?.classList.remove("opacity-0");
      b3?.classList.remove("-rotate-45", "-translate-y-2");
    }
  });
</script>
---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    title: t('srv1.title'),
    description: t('srv1.desc'),
    tags: ["Vector DB", "LLMs", "Embeddings"],
    iconId: "rag",
  },
  {
    title: t('srv2.title'),
    description: t('srv2.desc'),
    tags: ["LangChain", "Workflows", "Automation"],
    iconId: "agents",
  },
  {
    title: t('srv3.title'),
    description: t('srv3.desc'),
    tags: ["Data Engineering", "Python", "LlamaIndex"],
    iconId: "pipelines",
  },
  {
    title: t('srv4.title'),
    description: t('srv4.desc'),
    tags: ["Astro", "Dashboards", "TypeScript"],
    iconId: "tools",
  },
  {
    title: t('srv5.title'),
    description: t('srv5.desc'),
    tags: ["API", "OpenAI", "Anthropic"],
    iconId: "api",
  },
  {
    title: t('srv6.title'),
    description: t('srv6.desc'),
    tags: ["Docker", "Coolify", "Security"],
    iconId: "mlops",
  },
];
---

<section id="services" class="py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center mb-16">
      <span class="inline-block text-blue-400 text-sm font-semibold uppercase tracking-widest mb-4">
        {t('services.label')}
      </span>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-4">
        {t('services.title1')}
        <span class="text-zinc-500">{t('services.title2')}</span>
      </h2>
      <p class="max-w-xl mx-auto text-zinc-400 text-lg">
        {t('services.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="group relative p-8 rounded-2xl bg-zinc-900 border border-zinc-800 hover:border-blue-500/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-blue-500/5">
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-blue-600/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          <div class="relative">

            <div class="mb-6 w-12 h-12">

              {service.iconId === "rag" && (
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12">
                  <ellipse cx="24" cy="36" rx="14" ry="4" stroke="#3b82f6" stroke-width="1.5" fill="none" class="animate-[pulse_3s_ease-in-out_infinite]"/>
                  <ellipse cx="24" cy="28" rx="14" ry="4" stroke="#3b82f6" stroke-width="1.5" fill="none"/>
                  <ellipse cx="24" cy="20" rx="14" ry="4" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <line x1="10" y1="20" x2="10" y2="36" stroke="#3b82f6" stroke-width="1.5"/>
                  <line x1="38" y1="20" x2="38" y2="36" stroke="#3b82f6" stroke-width="1.5"/>
                  <circle cx="24" cy="14" r="2" fill="#60a5fa" class="animate-[bounce_2s_ease-in-out_infinite]"/>
                  <line x1="24" y1="16" x2="24" y2="20" stroke="#60a5fa" stroke-width="1" stroke-dasharray="2 2" class="animate-[pulse_2s_ease-in-out_infinite]"/>
                </svg>
              )}

              {service.iconId === "agents" && (
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12">
                  <rect x="12" y="14" width="24" height="18" rx="4" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <circle cx="19" cy="22" r="2.5" fill="#3b82f6" class="animate-[ping_3s_ease-in-out_infinite]"/>
                  <circle cx="19" cy="22" r="2.5" fill="#60a5fa"/>
                  <circle cx="29" cy="22" r="2.5" fill="#3b82f6" class="animate-[ping_3s_ease-in-out_infinite_0.5s]"/>
                  <circle cx="29" cy="22" r="2.5" fill="#60a5fa"/>
                  <line x1="24" y1="8" x2="24" y2="14" stroke="#60a5fa" stroke-width="1.5"/>
                  <circle cx="24" cy="7" r="2" fill="#60a5fa" class="animate-[pulse_1.5s_ease-in-out_infinite]"/>
                  <rect x="17" y="32" width="14" height="7" rx="2" stroke="#3b82f6" stroke-width="1.5" fill="none"/>
                  <line x1="12" y1="35" x2="17" y2="35" stroke="#3b82f6" stroke-width="1.5"/>
                  <line x1="31" y1="35" x2="36" y2="35" stroke="#3b82f6" stroke-width="1.5"/>
                </svg>
              )}

              {service.iconId === "pipelines" && (
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12">
                  <circle cx="10" cy="24" r="4" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <circle cx="24" cy="12" r="4" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <circle cx="24" cy="36" r="4" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <circle cx="38" cy="24" r="4" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <line x1="14" y1="22" x2="20" y2="15" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="3 2"/>
                  <line x1="14" y1="26" x2="20" y2="33" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="3 2"/>
                  <line x1="28" y1="14" x2="34" y2="21" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="3 2"/>
                  <line x1="28" y1="34" x2="34" y2="27" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="3 2"/>
                  <circle cx="17" cy="18" r="1.5" fill="#60a5fa" class="animate-[ping_2s_ease-in-out_infinite]"/>
                  <circle cx="31" cy="17" r="1.5" fill="#60a5fa" class="animate-[ping_2s_ease-in-out_infinite_0.7s]"/>
                  <circle cx="17" cy="30" r="1.5" fill="#60a5fa" class="animate-[ping_2s_ease-in-out_infinite_1.4s]"/>
                </svg>
              )}

              {service.iconId === "tools" && (
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12">
                  <rect x="6" y="10" width="36" height="28" rx="3" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <line x1="6" y1="17" x2="42" y2="17" stroke="#3b82f6" stroke-width="1.5"/>
                  <circle cx="11" cy="13.5" r="1.5" fill="#3b82f6"/>
                  <circle cx="16" cy="13.5" r="1.5" fill="#3b82f6"/>
                  <circle cx="21" cy="13.5" r="1.5" fill="#3b82f6"/>
                  <line x1="12" y1="23" x2="28" y2="23" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round" class="animate-[pulse_2s_ease-in-out_infinite]"/>
                  <line x1="12" y1="28" x2="22" y2="28" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round" class="animate-[pulse_2s_ease-in-out_infinite_0.4s]"/>
                  <line x1="12" y1="33" x2="32" y2="33" stroke="#60a5fa" stroke-width="1.5" stroke-linecap="round" class="animate-[pulse_2s_ease-in-out_infinite_0.8s]"/>
                  <rect x="29" y="21" width="2" height="4" rx="1" fill="#60a5fa" class="animate-[pulse_1s_ease-in-out_infinite]"/>
                </svg>
              )}

              {service.iconId === "api" && (
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12">
                  <circle cx="24" cy="24" r="5" fill="#1d4ed8" stroke="#60a5fa" stroke-width="1.5"/>
                  <circle cx="24" cy="24" r="5" stroke="#3b82f6" stroke-width="6" stroke-opacity="0.15" class="animate-[ping_2.5s_ease-in-out_infinite]"/>
                  <circle cx="24" cy="9" r="3" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <circle cx="39" cy="24" r="3" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <circle cx="24" cy="39" r="3" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <circle cx="9" cy="24" r="3" stroke="#60a5fa" stroke-width="1.5" fill="none"/>
                  <line x1="24" y1="12" x2="24" y2="19" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="2 2"/>
                  <line x1="36" y1="24" x2="29" y2="24" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="2 2"/>
                  <line x1="24" y1="36" x2="24" y2="29" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="2 2"/>
                  <line x1="12" y1="24" x2="19" y2="24" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="2 2"/>
                  <circle cx="24" cy="14" r="1.5" fill="#60a5fa" class="animate-[bounce_2s_ease-in-out_infinite]"/>
                  <circle cx="34" cy="24" r="1.5" fill="#60a5fa" class="animate-[bounce_2s_ease-in-out_infinite_0.5s]"/>
                </svg>
              )}

              {service.iconId === "mlops" && (
                <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12">
                  <path d="M14 30a7 7 0 01-.5-14 8 8 0 0115.5-2A6 6 0 1136 30H14z" stroke="#60a5fa" stroke-width="1.5" fill="none" class="animate-[pulse_3s_ease-in-out_infinite]"/>
                  <line x1="24" y1="32" x2="24" y2="41" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round"/>
                  <polyline points="20,38 24,42 28,38" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="32" cy="36" r="1.5" fill="#60a5fa" class="animate-[ping_2s_ease-in-out_infinite_1s]"/>
                  <circle cx="16" cy="38" r="1.5" fill="#60a5fa" class="animate-[ping_2s_ease-in-out_infinite_0.3s]"/>
                </svg>
              )}

            </div>

            <h3 class="text-xl font-bold text-white mb-3">{service.title}</h3>
            <p class="text-zinc-400 text-sm leading-relaxed mb-6">
              {service.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {service.tags.map((tag) => (
                <span class="px-3 py-1 rounded-full bg-zinc-800 text-zinc-400 text-xs font-medium border border-zinc-700">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>